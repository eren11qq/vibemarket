# ── Vibe Market 环境变量配置 ──
#
# 复制此文件为 .env 并填写真实值即可部署
# cp .env.example .env

# 服务器端口（默认 3456）
PORT=3456

# 运行环境: development | production
# production 模式会强制检查 JWT_SECRET 和 ADMIN_PASSWORD
NODE_ENV=development

# ── 安全必填项（production 模式下缺失会导致启动失败）──

# JWT Token 签名密钥（生产环境请使用足够长的随机字符串）
JWT_SECRET=your-secret-key-change-this-in-production

# 管理员默认密码（生产环境请修改）
ADMIN_PASSWORD=change-me-on-first-run

# ── 可选配置 ──

# 网站基础 URL（用于生成邮箱验证链接等，生产环境必须设置！）
BASE_URL=http://localhost:3456

# 管理员用户名（默认 admin）
ADMIN_USERNAME=admin

# 允许跨域的域名，多个用逗号分隔
# 生产环境留空 = 禁止跨域请求；development 不设置 = 允许所有来源
# CORS_ORIGIN=https://yourdomain.com,https://www.yourdomain.com

# 是否启用信任代理（部署在 Nginx 反代后需要设为 true）
TRUST_PROXY=false

# ── 邮件服务（可选，用于找回密码功能）──

# SMTP 服务器地址（留空 = 不启用邮件，令牌打印在控制台）
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your-email-password
SMTP_FROM=noreply@vibemarket.com
